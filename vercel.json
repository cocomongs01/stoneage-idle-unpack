{
  "rewrites": [
    {
      "source": "/assets/pets/(.*)-portrait.png",
      "destination": "/assets/pets/$1-portrait.webp"
    },
    {
      "source": "/assets/backgrounds/hero_info_full/(.*).png",
      "destination": "/assets/backgrounds/hero_info_full/$1.webp"
    },
    {
      "source": "/assets/backgrounds/weapons/(.*).png",
      "destination": "/assets/backgrounds/weapons/$1.webp"
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/viewer.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/data.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/extra_pet_data.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/spine_manifest_index.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/viewer.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/viewer-mobile.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/vendor/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
